FROM python:3.12.12-alpine3.22 AS build-env

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt --target=/app/site-packages --only-binary=:all:


FROM python:3.12.12-alpine3.22

COPY --from=build-env /app/site-packages /app/site-packages
ENV PYTHONPATH=/app/site-packages

WORKDIR /app
COPY . .

EXPOSE 8000
CMD ["python", "-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]